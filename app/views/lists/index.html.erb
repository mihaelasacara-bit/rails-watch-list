<div class="m-3 d-flex justify-content-between">
  <h1>Watch Lists</h1>
  <button class="btn btn-primary"><%= link_to "Create List", new_list_path %></button>
</div>
<div class="m-3">
  <ul class="list-inline">
    <% @lists.each do |list| %>
      <li class="list-inline-item">🎬 <%= link_to list.name, list_path(list) %></li>
  <% end %>
</div>
