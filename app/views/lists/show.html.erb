<div class="m-3 d-flex justify-content-between">
  <h1><%= @list.name %></h1>
  <button class="btn btn-primary"><%= link_to "Add Bookmark", new_list_bookmark_path(@list) %></button>
</div>
<div class="m-3 d-flex">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="card" style="width: 18rem;">
        <img src=<%= bookmark.movie.poster_url %> class="card-img-top" alt="...">
        <div class="card-body">
          <h5 class="card-title"><%= bookmark.movie.title %></h5>
          <p class="card-text"><%= bookmark.movie.overview%></p>
          <button class="btn btn-light"><%= link_to "🗑️",  bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %></button>
        </div>
      </div>
    <% end %>
</div>
<div class="m-3 back-link">
  <%= link_to "⬅ Back to Watch List", lists_path %>
</div>
